                            <button
                              class="button-show-more link underlined-link"
                              id="Show-More-{{ section.id }}"
                              type="button"
                            >
                              <span class="label-show-more label-text"
                                ><span aria-hidden="true">+ </span>{{ 'products.facets.show_more' | t }}
                              </span>
                            </button>
                          </show-more-button>
                        {%- endif -%}
                      {%- endif -%}
                    </volume-pricing>
                  {%- endif -%}
                </div>
              {%- when 'popup' -%}
                <modal-opener
                  class="product-popup-modal__opener quick-add-hidden"
                  data-modal="#PopupModal-{{ block.id }}"
                  {{ block.shopify_attributes }}
                >
                  <button
                    id="ProductPopup-{{ block.id }}"
                    class="product-popup-modal__button link"
                    type="button"
                    aria-haspopup="dialog"
                  >
                    {{ block.settings.text | default: block.settings.page.title | escape }}
                  </button>
                </modal-opener>
              {%- when 'share' -%}
                {% liquid
                  assign share_url = product.selected_variant.url | default: product.url | prepend: request.origin
                  render 'share-button', block: block, share_link: share_url
                %}

              {%- when 'variant_picker' -%}
                {% render 'product-variant-picker', product: product, block: block, product_form_id: product_form_id %}
              {%- when 'buy_buttons' -%}
                {%- comment -%} Personalisation — name tags (tag: personnalisable) or logo upload (tag: logo-upload) {%- endcomment -%}
                {%- assign is_name_product = false -%}
                {%- assign is_logo_product = false -%}
                {%- assign is_single_name = false -%}
                {%- if product.tags contains 'personnalisable' -%}{%- assign is_name_product = true -%}{%- endif -%}
                {%- if product.tags contains 'logo-upload' -%}{%- assign is_logo_product = true -%}{%- endif -%}
                {%- if product.tags contains 'single-name' -%}{%- assign is_single_name = true -%}{%- endif -%}

                {%- if is_name_product or is_logo_product -%}
                  <div class="originea-personalisation originea-personalisation-block-{{ section.id }}" {{ block.shopify_attributes }}>
                    <h3 class="originea-personalisation__title">Personnalisation</h3>

                    {%- if is_name_product -%}
                      {%- comment -%} Font selector {%- endcomment -%}
                      <div class="originea-font-selector">
                        <p class="originea-font-selector__label">Style d'écriture</p>
                        <div class="originea-font-selector__options">
                          <label class="originea-font-option">
                            <input type="radio" name="originea_font_{{ section.id }}" value="Cinzel" checked>
                            <span class="originea-font-option__preview" style="font-family:'OrigineaCinzel',serif;">Camille</span>
                            <span class="originea-font-option__name">Cinzel</span>
                          </label>
                          <label class="originea-font-option">
                            <input type="radio" name="originea_font_{{ section.id }}" value="GreatVibes">
                            <span class="originea-font-option__preview" style="font-family:'OrigineaGreatVibes',cursive;">Camille</span>
                            <span class="originea-font-option__name">Great Vibes</span>
                          </label>
                          <label class="originea-font-option">
                            <input type="radio" name="originea_font_{{ section.id }}" value="Corinthia">
                            <span class="originea-font-option__preview" style="font-family:'OrigineaCorinthia',cursive;">Camille</span>
                            <span class="originea-font-option__name">Corinthia</span>
                          </label>
                          <label class="originea-font-option">
                            <input type="radio" name="originea_font_{{ section.id }}" value="Inspiration">
                            <span class="originea-font-option__preview" style="font-family:'OrigineaInspiration',cursive;">Camille</span>
                            <span class="originea-font-option__name">Inspiration</span>
                          </label>
                          <label class="originea-font-option">
                            <input type="radio" name="originea_font_{{ section.id }}" value="PinyonScript">
                            <span class="originea-font-option__preview" style="font-family:'OrigineaPinyonScript',cursive;">Camille</span>
                            <span class="originea-font-option__name">Pinyon Script</span>
                          </label>
                          <label class="originea-font-option">
                            <input type="radio" name="originea_font_{{ section.id }}" value="PlaylistScript">
                            <span class="originea-font-option__preview" style="font-family:'OrigineaPlaylistScript',cursive;">Camille</span>
                            <span class="originea-font-option__name">Playlist Script</span>
                          </label>
                        </div>
                        <input type="hidden" name="properties[Style d'écriture]" form="{{ product_form_id }}" id="originea-font-hidden-{{ section.id }}" value="Cinzel">
                      </div>

                      {%- comment -%} Live preview card {%- endcomment -%}
                      <div class="originea-preview" id="originea-preview-{{ section.id }}">
                        <div class="originea-preview__card">
                          <div class="originea-preview__name" id="originea-preview-name-{{ section.id }}" style="font-family:'OrigineaCinzel',serif;">{% if is_single_name %}Camille{% else %}Camille & Thomas{% endif %}</div>
                          {%- unless is_single_name -%}
                          <div class="originea-preview__divider" id="originea-preview-divider-{{ section.id }}" style="display:none;"></div>
                          <div class="originea-preview__date" id="originea-preview-date-{{ section.id }}" style="display:none;"></div>
                          {%- endunless -%}
                        </div>
                        <p class="originea-preview__hint">Aperçu en direct — saisissez vos prénoms ci-dessous</p>
                      </div>

                      {%- comment -%} Name rows {%- endcomment -%}
                      {%- if is_single_name -%}
                        <div class="originea-personalisation__rows-header" style="grid-template-columns: 2rem 1fr;">
                          <span></span>
                          <span>Prénom *</span>
                        </div>
                      {%- else -%}
                        <div class="originea-personalisation__rows-header">
                          <span></span>
                          <span>Prénom 1 *</span>
                          <span>Prénom 2</span>
                          <span>Date</span>
                        </div>
                      {%- endif -%}

                      <div id="originea-personalisation-rows-{{ section.id }}" class="originea-personalisation__rows"></div>

                      <div class="originea-personalisation__field" style="margin-top:1.2rem;">
                        <label for="message-{{ section.id }}" class="originea-personalisation__label">
                          Message commun <span class="originea-personalisation__optional">(optionnel)</span>
                        </label>
                        <textarea
                          id="message-{{ section.id }}"
                          name="properties[Message]"
                          form="{{ product_form_id }}"
                          placeholder="Ex : Avec tout notre amour..."
                          rows="3"
                          class="originea-personalisation__textarea"
                        ></textarea>
                      </div>

                      <p class="originea-personalisation__note">
                        Ces informations apparaîtront sur vos étiquettes personnalisées.
                        Délai de fabrication : <strong>4 jours ouvrés</strong>.
                      </p>
                    {%- endif -%}

                    {%- if is_logo_product -%}
                      {%- comment -%} Round sticker preview {%- endcomment -%}
                      <div class="originea-sticker-preview">
                        <div class="originea-sticker-preview__circle" id="originea-sticker-circle-{{ section.id }}">
                          <svg viewBox="0 0 300 300" xmlns="http://www.w3.org/2000/svg" class="originea-sticker-preview__example">
                            <circle cx="150" cy="150" r="140" fill="#faf8f5" stroke="#c8b99a" stroke-width="2"/>
                            <circle cx="150" cy="150" r="128" fill="none" stroke="#c8b99a" stroke-width="1"/>
                            <!-- Botanical left -->
                            <g stroke="#b8a882" stroke-width="1" fill="none">
                              <path d="M55,150 Q43,128 36,105"/>
                              <path d="M55,150 Q40,143 30,138"/>
                              <path d="M55,150 Q46,170 40,190"/>
                              <ellipse cx="36" cy="105" rx="7" ry="11" transform="rotate(-30,36,105)" fill="#c8b99a" stroke="none" opacity="0.65"/>
                              <ellipse cx="30" cy="138" rx="7" ry="10" transform="rotate(-60,30,138)" fill="#c8b99a" stroke="none" opacity="0.65"/>
                              <ellipse cx="40" cy="190" rx="7" ry="11" transform="rotate(20,40,190)" fill="#c8b99a" stroke="none" opacity="0.65"/>
                            </g>
                            <!-- Botanical right -->
                            <g stroke="#b8a882" stroke-width="1" fill="none">
                              <path d="M245,150 Q257,128 264,105"/>
                              <path d="M245,150 Q260,143 270,138"/>
                              <path d="M245,150 Q254,170 260,190"/>
                              <ellipse cx="264" cy="105" rx="7" ry="11" transform="rotate(30,264,105)" fill="#c8b99a" stroke="none" opacity="0.65"/>
                              <ellipse cx="270" cy="138" rx="7" ry="10" transform="rotate(60,270,138)" fill="#c8b99a" stroke="none" opacity="0.65"/>
                              <ellipse cx="260" cy="190" rx="7" ry="11" transform="rotate(-20,260,190)" fill="#c8b99a" stroke="none" opacity="0.65"/>
                            </g>
                            <!-- Names -->
                            <text x="150" y="130" text-anchor="middle" font-family="'OrigineaGreatVibes', cursive" font-size="36" fill="#4a3f35">Marie &amp; Thomas</text>
                            <!-- Divider -->
                            <line x1="90" y1="144" x2="210" y2="144" stroke="#c8b99a" stroke-width="1"/>
                            <!-- Date -->
                            <text x="150" y="164" text-anchor="middle" font-family="Georgia, serif" font-size="14" fill="#7a6a58" letter-spacing="3">24 . 06 . 2025</text>
                            <!-- Slogan -->
                            <text x="150" y="188" text-anchor="middle" font-family="Georgia, serif" font-size="12" fill="#9a8a78" letter-spacing="2" font-style="italic">Pour toujours &amp; à jamais</text>
                            <!-- Heart -->
                            <text x="150" y="212" text-anchor="middle" font-size="14" fill="#c8b99a">♡</text>
                          </svg>
                          <img id="originea-sticker-img-{{ section.id }}" src="" alt="Votre logo" style="display:none; width:100%; height:100%; object-fit:contain; border-radius:50%; padding:12px;">
                        </div>
                        <p class="originea-sticker-preview__hint">Aperçu du sticker rond — votre logo remplacera cet exemple</p>
                      </div>

                      {%- comment -%} Logo upload via Uploadcare {%- endcomment -%}
                      <div class="originea-logo-upload">
                        <p class="originea-personalisation__label">Votre logo <span class="originea-personalisation__required">*</span></p>
                        <p class="originea-logo-upload__desc">Formats acceptés : PNG, SVG, PDF. Fond transparent recommandé.</p>
                        <div class="originea-logo-upload__zone" id="originea-logo-zone-{{ section.id }}">
                          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                          <p>Glissez votre logo ici ou <span class="originea-logo-upload__browse">parcourir</span></p>
                          <input type="file" id="originea-logo-file-{{ section.id }}" accept=".png,.svg,.pdf,.jpg,.jpeg,.ai,.eps" style="display:none;">
                        </div>
                        <div class="originea-logo-upload__file-info" id="originea-logo-preview-{{ section.id }}" style="display:none;">
                          <div class="originea-logo-upload__preview-info">
                            <span id="originea-logo-filename-{{ section.id }}"></span>
                            <button type="button" class="originea-logo-upload__remove" id="originea-logo-remove-{{ section.id }}">✕ Supprimer</button>
                          </div>
                        </div>
                        <div class="originea-logo-upload__status" id="originea-logo-status-{{ section.id }}"></div>
                        <input type="hidden" name="properties[Logo URL]" form="{{ product_form_id }}" id="originea-logo-url-{{ section.id }}">
                        <input type="hidden" name="properties[Logo fichier]" form="{{ product_form_id }}" id="originea-logo-name-{{ section.id }}">
                        <p class="originea-logo-upload__error" id="originea-logo-error-{{ section.id }}" style="display:none;">
                          ⚠️ Veuillez télécharger votre logo avant de continuer.
                        </p>
                      </div>

                      <p class="originea-personalisation__note">
                        Votre logo sera imprimé sur un sticker rond personnalisé.
                        Délai de fabrication : <strong>4 jours ouvrés</strong>.
                      </p>
                    {%- endif -%}

                  </div>

                  <style>
                    @font-face { font-family: 'OrigineaCinzel'; src: url('{{ 'font-cinzel-regular.ttf' | asset_url }}') format('truetype'); font-display: swap; }
                    @font-face { font-family: 'OrigineaGreatVibes'; src: url('{{ 'font-greatvibes-regular.ttf' | asset_url }}') format('truetype'); font-display: swap; }
                    @font-face { font-family: 'OrigineaCorinthia'; src: url('{{ 'font-corinthia-regular.ttf' | asset_url }}') format('truetype'); font-display: swap; }
                    @font-face { font-family: 'OrigineaInspiration'; src: url('{{ 'font-inspiration-regular.ttf' | asset_url }}') format('truetype'); font-display: swap; }
                    @font-face { font-family: 'OrigineaPinyonScript'; src: url('{{ 'font-pinyonscript-regular.ttf' | asset_url }}') format('truetype'); font-display: swap; }
                    @font-face { font-family: 'OrigineaPlaylistScript'; src: url('{{ 'font-playlistscript-regular.otf' | asset_url }}') format('opentype'); font-display: swap; }
                  </style>

                  <script>
                    (function() {
                      var formId = {{ product_form_id | json }};
                      var sectionId = {{ section.id | json }};
                      var product = {{ product | json }};
                      var isSingleName = {{ is_single_name | json }};
                      var isNameProduct = {{ is_name_product | json }};
                      var isLogoProduct = {{ is_logo_product | json }};
                      var UPLOADCARE_KEY = '7abc11da2e59a8bc3e3c';

                      var fontFamilies = {
                        'Cinzel': "'OrigineaCinzel', serif",
                        'GreatVibes': "'OrigineaGreatVibes', cursive",
                        'Corinthia': "'OrigineaCorinthia', cursive",
                        'Inspiration': "'OrigineaInspiration', cursive",
                        'PinyonScript': "'OrigineaPinyonScript', cursive",
                        'PlaylistScript': "'OrigineaPlaylistScript', cursive"
                      };

                      // --- Helpers ---

                      function getOptionIndex(name) {
                        return product.options.map(function(o) { return o.toLowerCase(); }).indexOf(name.toLowerCase());
                      }

                      function getCountFromVariant(variant) {
                        var formatIdx = getOptionIndex('Format');
                        if (formatIdx >= 0 && variant && variant.options) {
                          var val = parseInt(variant.options[formatIdx]);
                          if (val) return val;
                        }
                        return null;
                      }

                      function getInitialCount() {
                        var formatIdx = getOptionIndex('Format');
                        if (formatIdx >= 0) {
                          var checked = document.querySelector('input[name="options[Format]"]:checked');
                          if (checked) return parseInt(checked.value) || 10;
                          return 10;
                        }
                        var match = product.title.match(/\b(\d+)\b/);
                        return match ? parseInt(match[1]) : 1;
                      }

                      function isPersonnalisationActive(variant) {
                        if (!variant) return true;
                        // Check options array by index
                        var idx = getOptionIndex('Personnalisation');
                        if (idx >= 0 && variant.options) {
                          return variant.options[idx] === 'Avec personnalisation';
                        }
                        // Fallback: scan all options for Avec/Sans value
                        if (variant.options) {
                          for (var i = 0; i < variant.options.length; i++) {
                            if (variant.options[i] === 'Sans personnalisation') return false;
                            if (variant.options[i] === 'Avec personnalisation') return true;
                          }
                        }
                        return true;
                      }

                      function getInitialPersonnalisationActive() {
                        // Dawn renders pill inputs with name="{{ option.name }}-{{ option.position }}"
                        // Most reliable: check which variant is currently selected via the hidden id input
                        var variantInput = document.querySelector('input[name="id"]');
                        if (variantInput) {
                          var vid = parseInt(variantInput.value);
                          var v = product.variants.find(function(x) { return x.id === vid; });
                          if (v) return isPersonnalisationActive(v);
                        }
                        // Fallback: scan all checked radio inputs for Avec/Sans value
                        var allChecked = document.querySelectorAll('input[type="radio"]:checked');
                        for (var i = 0; i < allChecked.length; i++) {
                          if (allChecked[i].value === 'Sans personnalisation') return false;
                          if (allChecked[i].value === 'Avec personnalisation') return true;
                        }
                        return true;
                      }

                      function toggleBlock(show) {
                        var block = document.querySelector('.originea-personalisation-block-' + sectionId)
                                 || document.querySelector('.originea-personalisation');
                        if (!block) return;
                        block.style.display = show ? '' : 'none';
                        block.querySelectorAll('input[required]').forEach(function(el) { el.disabled = !show; });
                      }

                      // --- Font selector ---

                      function initFontSelector() {
                        var radios = document.querySelectorAll('input[name="originea_font_' + sectionId + '"]');
                        var hidden = document.getElementById('originea-font-hidden-' + sectionId);
                        var previewName = document.getElementById('originea-preview-name-' + sectionId);

                        radios.forEach(function(radio) {
                          radio.addEventListener('change', function() {
                            var font = fontFamilies[this.value] || fontFamilies['Cinzel'];
                            hidden.value = this.value;
                            if (previewName) previewName.style.fontFamily = font;
                          });
                        });
                      }

                      // --- Live preview ---

                      function updatePreview(p1val, p2val, dtval) {
                        var previewName = document.getElementById('originea-preview-name-' + sectionId);
                        var previewDate = document.getElementById('originea-preview-date-' + sectionId);
                        var previewDivider = document.getElementById('originea-preview-divider-' + sectionId);
                        if (!previewName) return;

                        var name = p1val || (isSingleName ? 'Camille' : 'Camille & Thomas');
                        if (!isSingleName && p2val) name += ' & ' + p2val;
                        previewName.textContent = name;

                        if (previewDate) {
                          var hasDate = dtval && dtval.trim() !== '';
                          previewDate.textContent = hasDate ? dtval : '';
                          previewDate.style.display = hasDate ? '' : 'none';
                          if (previewDivider) previewDivider.style.display = hasDate ? '' : 'none';
                        }
                      }

                      // --- Build rows ---

                      function buildRows(count) {
                        var container = document.getElementById('originea-personalisation-rows-' + sectionId);
                        if (!container) return;
                        container.innerHTML = '';

                        for (var i = 1; i <= count; i++) {
                          var row = document.createElement('div');
                          row.className = 'originea-personalisation__row' + (isSingleName ? ' originea-personalisation__row--single' : '');

                          var hiddenNoms = document.createElement('input');
                          hiddenNoms.type = 'hidden';
                          hiddenNoms.name = 'properties[Étiquette ' + i + ' — Noms]';
                          hiddenNoms.form = formId;
                          row.appendChild(hiddenNoms);

                          var num = document.createElement('span');
                          num.className = 'originea-personalisation__row-num';
                          num.textContent = i;
                          row.appendChild(num);

                          var p1 = document.createElement('input');
                          p1.type = 'text';
                          p1.placeholder = isSingleName ? 'Ex : Camille' : 'Ex : Camille';
                          p1.required = true;
                          p1.className = 'originea-personalisation__input';
                          row.appendChild(p1);

                          var p2, dt, hiddenDate;

                          if (!isSingleName) {
                            p2 = document.createElement('input');
                            p2.type = 'text';
                            p2.placeholder = 'Ex : Thomas';
                            p2.className = 'originea-personalisation__input';
                            row.appendChild(p2);

                            hiddenDate = document.createElement('input');
                            hiddenDate.type = 'hidden';
                            hiddenDate.name = 'properties[Étiquette ' + i + ' — Date]';
                            hiddenDate.form = formId;
                            row.appendChild(hiddenDate);

                            dt = document.createElement('input');
                            dt.type = 'text';
                            dt.placeholder = 'JJ.MM.AAAA';
                            dt.maxLength = 10;
                            dt.inputMode = 'numeric';
                            dt.className = 'originea-personalisation__input';
                            row.appendChild(dt);
                          }

                          // Combine names + update preview on row 1
                          (function(p1el, p2el, dtEl, hiddenNomsEl, hiddenDateEl, rowIndex) {
                            function updateNoms() {
                              var v1 = p1el.value.trim();
                              var v2 = p2el ? p2el.value.trim() : '';
                              hiddenNomsEl.value = v2 ? v1 + ' & ' + v2 : v1;
                              if (rowIndex === 1) updatePreview(v1, v2, dtEl ? dtEl.value.trim() : '');
                            }
                            p1el.addEventListener('input', updateNoms);
                            if (p2el) p2el.addEventListener('input', updateNoms);

                            if (dtEl && hiddenDateEl) {
                              // Date mask: auto-insert dots after DD and MM
                              dtEl.addEventListener('keydown', function(e) {
                                // Allow: backspace, delete, tab, arrows
                                if ([8, 9, 37, 38, 39, 40, 46].indexOf(e.keyCode) !== -1) return;
                                // Block non-numeric keys
                                if (e.key && !/^\d$/.test(e.key)) e.preventDefault();
                              });

                              dtEl.addEventListener('input', function() {
                                var digits = this.value.replace(/\D/g, '').slice(0, 8);
                                var masked = '';
                                if (digits.length <= 2) {
                                  masked = digits;
                                } else if (digits.length <= 4) {
                                  masked = digits.slice(0, 2) + '.' + digits.slice(2);
                                } else {
                                  masked = digits.slice(0, 2) + '.' + digits.slice(2, 4) + '.' + digits.slice(4);
                                }
                                this.value = masked;
                                hiddenDateEl.value = masked;
                                if (rowIndex === 1) updatePreview(p1el.value.trim(), p2el ? p2el.value.trim() : '', masked);
                              });
                            }
                          })(p1, p2, dt, hiddenNoms, hiddenDate, i);

                          container.appendChild(row);
                        }
                      }

                      // --- Logo upload via Uploadcare ---

                      function initLogoUpload() {
                        var zone = document.getElementById('originea-logo-zone-' + sectionId);
                        var fileInput = document.getElementById('originea-logo-file-' + sectionId);
                        var preview = document.getElementById('originea-logo-preview-' + sectionId);
                        var stickerImg = document.getElementById('originea-sticker-img-' + sectionId);
                        var stickerSvg = zone ? (zone.closest('.originea-personalisation') || document).querySelector('.originea-sticker-preview__example') : null;
                        var filenameEl = document.getElementById('originea-logo-filename-' + sectionId);
                        var removeBtn = document.getElementById('originea-logo-remove-' + sectionId);
                        var statusEl = document.getElementById('originea-logo-status-' + sectionId);
                        var urlInput = document.getElementById('originea-logo-url-' + sectionId);
                        var nameInput = document.getElementById('originea-logo-name-' + sectionId);

                        if (!zone) return;

                        zone.addEventListener('click', function() { fileInput.click(); });
                        zone.querySelector('.originea-logo-upload__browse').addEventListener('click', function(e) {
                          e.stopPropagation();
                          fileInput.click();
                        });

                        // Drag & drop
                        zone.addEventListener('dragover', function(e) { e.preventDefault(); zone.classList.add('originea-logo-upload__zone--drag'); });
                        zone.addEventListener('dragleave', function() { zone.classList.remove('originea-logo-upload__zone--drag'); });
                        zone.addEventListener('drop', function(e) {
                          e.preventDefault();
                          zone.classList.remove('originea-logo-upload__zone--drag');
                          if (e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]);
                        });

                        fileInput.addEventListener('change', function() {
                          if (this.files[0]) handleFile(this.files[0]);
                        });

                        removeBtn.addEventListener('click', function() {
                          preview.style.display = 'none';
                          zone.style.display = '';
                          urlInput.value = '';
                          nameInput.value = '';
                          fileInput.value = '';
                          statusEl.textContent = '';
                          if (stickerImg) { stickerImg.style.display = 'none'; stickerImg.src = ''; }
                          if (stickerSvg) { stickerSvg.style.display = ''; }
                        });

                        function handleFile(file) {
                          statusEl.textContent = 'Envoi en cours...';
                          statusEl.className = 'originea-logo-upload__status originea-logo-upload__status--loading';

                          // Show local preview in round sticker circle
                          if (file.type.startsWith('image/')) {
                            var reader = new FileReader();
                            reader.onload = function(e) {
                              if (stickerImg) {
                                stickerImg.src = e.target.result;
                                stickerImg.style.display = '';
                              }
                              if (stickerSvg) { stickerSvg.style.display = 'none'; }
                            };
                            reader.readAsDataURL(file);
                          } else {
                            if (stickerSvg) { stickerSvg.style.display = 'none'; }
                          }
                          filenameEl.textContent = file.name;
                          preview.style.display = '';
                          zone.style.display = 'none';
                          nameInput.value = file.name;

                          // Upload to Uploadcare
                          var formData = new FormData();
                          formData.append('UPLOADCARE_PUB_KEY', UPLOADCARE_KEY);
                          formData.append('UPLOADCARE_STORE', '1');
                          formData.append('file', file);

                          fetch('https://upload.uploadcare.com/base/', {
                            method: 'POST',
                            body: formData
                          })
                          .then(function(r) { return r.json(); })
                          .then(function(data) {
                            if (data.file) {
                              var fileUrl = 'https://ucarecdn.com/' + data.file + '/';
                              urlInput.value = fileUrl;
                              statusEl.textContent = '✓ Logo téléchargé avec succès';
                              statusEl.className = 'originea-logo-upload__status originea-logo-upload__status--success';
                              var errorEl = document.getElementById('originea-logo-error-' + sectionId);
                              if (errorEl) errorEl.style.display = 'none';
                            } else {
                              throw new Error('Upload failed');
                            }
                          })
                          .catch(function() {
                            statusEl.textContent = '✗ Erreur lors du téléchargement. Veuillez réessayer.';
                            statusEl.className = 'originea-logo-upload__status originea-logo-upload__status--error';
                          });
                        }
                      }

                      // --- Init ---

                      function init() {
                        if (isNameProduct) {
                          var currentCount = getInitialCount();
                          buildRows(currentCount);
                          initFontSelector();
                          toggleBlock(getInitialPersonnalisationActive());

                          if (typeof subscribe !== 'undefined' && typeof PUB_SUB_EVENTS !== 'undefined') {
                            subscribe(PUB_SUB_EVENTS.variantChange, function(event) {
                              var variant = event && event.data && event.data.variant;
                              if (!variant) return;
                              var newCount = getCountFromVariant(variant);
                              if (newCount && newCount !== currentCount) {
                                currentCount = newCount;
                                buildRows(currentCount);
                              }
                              toggleBlock(isPersonnalisationActive(variant));
                            });
                          }
                        }

                        if (isLogoProduct) {
                          initLogoUpload();

                          // Run on load
                          toggleBlock(getInitialPersonnalisationActive());

                          // Event delegation — fires on radio click before Dawn re-renders DOM
                          document.addEventListener('change', function(e) {
                            if (e.target && e.target.type === 'radio') {
                              if (e.target.value === 'Sans personnalisation') toggleBlock(false);
                              else if (e.target.value === 'Avec personnalisation') toggleBlock(true);
                            }
                          });

                          // Block form submit if Avec personnalisation selected but no logo uploaded
                          document.addEventListener('submit', function(e) {
                            var form = document.getElementById('product-form-' + sectionId);
                            if (!form || !e.target.contains(form) && e.target !== form) return;

                            // Check if personnalisation is active
                            var urlInput = document.getElementById('originea-logo-url-' + sectionId);
                            if (!urlInput || urlInput.value.trim() !== '') return; // logo uploaded, allow

                            // Check if Avec personnalisation is selected
                            var isActive = false;
                            var allRadios = document.querySelectorAll('input[type="radio"]:checked');
                            for (var i = 0; i < allRadios.length; i++) {
                              if (allRadios[i].value === 'Avec personnalisation') { isActive = true; break; }
                            }
                            if (!isActive) return; // Sans personnalisation, allow

                            // Block and show error
                            e.preventDefault();
                            e.stopPropagation();
                            var errorEl = document.getElementById('originea-logo-error-' + sectionId);
                            if (errorEl) {
                              errorEl.style.display = '';
                              errorEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
                            }
                          }, true);
                        }
                      }

                      if (document.readyState === 'loading') {
                        document.addEventListener('DOMContentLoaded', init);
                      } else {
                        init();
                      }
                    })();
                  </script>
                {%- endif -%}

                {%- render 'buy-buttons',
                  block: block,
                  product: product,
                  product_form_id: product_form_id,
                  section_id: section.id,
                  show_pickup_availability: true
                -%}
              {%- when 'trust_badges' -%}
                <div class="originea-trust-badges" {{ block.shopify_attributes }}>
                  <div class="originea-trust-badge">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    <span>PAIEMENT SÉCURISÉ</span>
                  </div>
                  <div class="originea-trust-badge">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2z"/><path d="M12 8c-2.2 0-4 1.8-4 4 1.1.7 2.4 1 3.8 1H12"/><path d="M12 8c2.2 0 4 1.8 4 4-1.1.7-2.4 1-3.8 1H12"/><line x1="12" y1="12" x2="12" y2="20"/></svg>
                    <span>100% NATUREL &amp; VEGAN</span>
                  </div>
                  <div class="originea-trust-badge">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                    <span>LIVRAISON GRATUITE DÈS 45€</span>
                  </div>
                </div>
              {%- when 'rating' -%}
                {%- liquid
                  assign p_jdgm_rating = product.metafields.judgeme.rating
                  assign p_jdgm_count  = product.metafields.judgeme.reviews_count
                  assign p_rev_rating  = product.metafields.reviews.rating.value.rating
                  assign p_rev_count   = product.metafields.reviews.rating_count
                  if p_jdgm_rating != blank
                    assign p_display_rating = p_jdgm_rating | plus: 0
                    assign p_display_count  = p_jdgm_count
                  elsif p_rev_rating != blank
                    assign p_display_rating = p_rev_rating | plus: 0
                    assign p_display_count  = p_rev_count
                  else
                    assign p_display_rating = nil
                  endif
                -%}
                {%- if p_display_rating != nil -%}
                  {%- comment -%} Link scrolls to Judge.me review widget on click {%- endcomment -%}
                  <a href="#jdgm-widget" class="originea-stars-link" aria-label="Voir les avis clients">
                    <div class="originea-stars originea-stars--product" aria-label="{{ p_display_rating | round: 1 }} out of 5 stars">
                      {%- assign p_full  = p_display_rating | floor -%}
                      {%- assign p_half  = false -%}
                      {%- assign p_dec   = p_display_rating | modulo: 1 -%}
                      {%- if p_dec >= 0.3 and p_dec < 0.8 -%}{%- assign p_half = true -%}{%- endif -%}
                      {%- if p_dec >= 0.8 -%}{%- assign p_full = p_full | plus: 1 -%}{%- endif -%}
                      {%- assign p_half_pos = p_full | plus: 1 -%}
                      {%- for i in (1..5) -%}
                        {%- if i <= p_full -%}
                          <span class="originea-star originea-star--full" aria-hidden="true">★</span>
                        {%- elsif p_half and i == p_half_pos -%}
                          <span class="originea-star originea-star--half" aria-hidden="true">★</span>
                        {%- else -%}
                          <span class="originea-star originea-star--empty" aria-hidden="true">★</span>
                        {%- endif -%}
                      {%- endfor -%}
                      {%- if p_display_count != blank and p_display_count != '0' and p_display_count != 0 -%}
                        <span class="originea-star-count">({{ p_display_count }})</span>
                      {%- endif -%}
                    </div>
                  </a>
                {%- endif -%}
              {%- when 'complementary' -%}
                <product-recommendations
                  class="complementary-products quick-add-hidden{% if block.settings.make_collapsible_row %} is-accordion{% endif %}{% if block.settings.enable_quick_add %} complementary-products-contains-quick-add{% endif %}"
                  data-url="{{ routes.product_recommendations_url }}?limit={{ block.settings.product_list_limit }}&intent=complementary"
                  data-section-id="{{ section.id }}"
                  data-product-id="{{ product.id }}"
                >
                  {%- if recommendations.performed and recommendations.products_count > 0 -%}
                    <aside
                      aria-label="{{ 'accessibility.complementary_products' | t }}"
                      {{ block.shopify_attributes -}}
                      {% if block.settings.make_collapsible_row %}
                        class="product__accordion accordion"
                      {% endif %}
                    >
                      <div class="complementary-products__container">
                        {%- if block.settings.make_collapsible_row -%}
                          <details id="Details-{{ block.id }}-{{ section.id }}" open>
                            <summary>
                        {%- endif %}
                        <div class="summary__title">
                          {%- if block.settings.make_collapsible_row -%}
                            {% render 'icon-accordion', icon: block.settings.icon %}
                            <h2 class="h4 accordion__title">{{ block.settings.block_heading }}</h2>
                          {%- else -%}
                            <h2 class="h3 accordion__title">{{ block.settings.block_heading }}</h2>
                          {%- endif -%}
                        </div>
                        {%- if block.settings.make_collapsible_row -%}
                          {{- 'icon-caret.svg' | inline_asset_content -}}
                          </summary>
                        {%- endif -%}
                        <slideshow-component class="slider-mobile-gutter">
                          {%- assign number_of_slides = recommendations.products_count
                            | plus: 0.0
                            | divided_by: block.settings.products_per_page
                            | ceil
                          -%}
                          <div
                            id="Slider-{{ block.id }}"
                            class="contains-card contains-card--product complementary-slider grid grid--1-col slider slider--everywhere"
                            role="list"
                            {% if number_of_slides > 1 %}
                              aria-label="{{ 'general.slider.name' | t }}"
                            {% endif %}
                          >
                            {% assign skip_card_product_styles = false %}
                            {%- for i in (1..number_of_slides) -%}
                              <div
                                id="Slide-{{ block.id }}-{{ forloop.index }}"
                                class="complementary-slide complementary-slide--{{ settings.card_style }} grid__item slider__slide slideshow__slide"
                                tabindex="-1"
                                role="group"
                                {% if number_of_slides > 1 %}
                                  aria-roledescription="{{ 'sections.slideshow.slide' | t }}"
                                  aria-label="{{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
                                {% endif %}
                              >
                                <ul class="list-unstyled" role="list">
                                  {%- for product in recommendations.products
                                    limit: block.settings.products_per_page
                                    offset: continue
                                  -%}
                                    <li>
                                      {%- if block.settings.enable_quick_add -%}
                                        {% assign quick_add = 'standard' %}
                                      {%- else -%}
                                        {% assign quick_add = 'none' %}
                                      {%- endif -%}
                                      {% render 'card-product',
                                        card_product: product,
                                        media_aspect_ratio: block.settings.image_ratio,
                                        show_secondary_image: false,
                                        lazy_load: false,
                                        skip_styles: skip_card_product_styles,
                                        quick_add: quick_add,
                                        section_id: section.id,
                                        horizontal_class: true,
                                        horizontal_quick_add: true
                                      %}
                                    </li>
                                    {%- assign skip_card_product_styles = true -%}
                                  {%- endfor -%}
                                </ul>
                              </div>
                            {%- endfor -%}
                          </div>
                          {%- if number_of_slides > 1 -%}
                            <div class="slider-buttons">
                              <button
                                type="button"
                                class="slider-button slider-button--prev"
                                name="previous"
                                aria-label="{{ 'general.slider.previous_slide' | t }}"
                              >
                                <span class="svg-wrapper">
                                  {{- 'icon-caret.svg' | inline_asset_content -}}
                                </span>
                              </button>
                              <div class="slider-counter slider-counter--{{ block.settings.pagination_style }}{% if block.settings.pagination_style == 'counter' or block.settings.pagination_style == 'numbers' %} caption{% endif %}">
                                {%- if block.settings.pagination_style == 'counter' -%}
                                  <span class="slider-counter--current">1</span>
                                  <span aria-hidden="true"> / </span>
                                  <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
                                  <span class="slider-counter--total">{{ number_of_slides }}</span>
                                {%- else -%}
                                  <div class="slideshow__control-wrapper">
                                    {%- for i in (1..number_of_slides) -%}
                                      <button
                                        class="slider-counter__link slider-counter__link--{{ block.settings.pagination_style }} link"
                                        aria-label="{{ 'sections.slideshow.load_slide' | t }} {{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}"
                                        aria-controls="Slider-{{ block.id }}"
                                      >
                                        {%- if block.settings.pagination_style == 'numbers' -%}
                                          {{ forloop.index -}}
                                        {%- else -%}
                                          <span class="dot"></span>
                                        {%- endif -%}
                                      </button>
                                    {%- endfor -%}
                                  </div>
                                {%- endif -%}
                              </div>
                              <button
                                type="button"
                                class="slider-button slider-button--next"
                                name="next"
                                aria-label="{{ 'general.slider.next_slide' | t }}"
                              >
                                <span class="svg-wrapper">
                                  {{- 'icon-caret.svg' | inline_asset_content -}}
                                </span>
                              </button>
                            </div>
                          {%- endif -%}
                        </slideshow-component>
                        {%- if block.settings.make_collapsible_row -%}
                          </details>
                        {%- endif -%}
                      </div>
                    </aside>
                  {%- endif -%}
                  {{ 'component-card.css' | asset_url | stylesheet_tag }}
                  {{ 'component-complementary-products.css' | asset_url | stylesheet_tag }}
                  {%- if block.settings.enable_quick_add -%}
                    {{ 'quick-add.css' | asset_url | stylesheet_tag }}
                    <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
                  {%- endif -%}
                </product-recommendations>
              {%- when 'icon-with-text' -%}
                {% render 'icon-with-text', block: block %}
            {%- endcase -%}
          {%- endfor -%}
          <a href="{{ product.url }}" class="link product__view-details animate-arrow">
            {{ 'products.product.view_full_details' | t }}
            {{- 'icon-arrow.svg' | inline_asset_content -}}
          </a>
        </section>
      </div>
    </div>

    {% render 'product-media-modal', variant_images: variant_images %}

    {% assign popups = section.blocks | where: 'type', 'popup' %}
    {%- for block in popups -%}
      <modal-dialog id="PopupModal-{{ block.id }}" class="product-popup-modal" {{ block.shopify_attributes }}>
        <div
          role="dialog"
          aria-label="{{ block.settings.text }}"
          aria-modal="true"
          class="product-popup-modal__content"
          tabindex="-1"
        >
          <button
            id="ModalClose-{{ block.id }}"
            type="button"
            class="product-popup-modal__toggle"
            aria-label="{{ 'accessibility.close' | t }}"
          >
            {{- 'icon-close.svg' | inline_asset_content -}}
          </button>
          <div class="product-popup-modal__content-info">
            <h1 class="h2">{{ block.settings.page.title | escape }}</h1>
            {{ block.settings.page.content }}
          </div>
        </div>
      </modal-dialog>
    {%- endfor -%}

    {%- if product.media.size > 0 -%}
      <script src="{{ 'product-modal.js' | asset_url }}" defer="defer"></script>
      <script src="{{ 'media-gallery.js' | asset_url }}" defer="defer"></script>
    {%- endif -%}

    {%- if first_3d_model -%}
      <script type="application/json" id="ProductJSON-{{ product.id }}">
        {{ product.media | where: 'media_type', 'model' | json }}
      </script>
      <script src="{{ 'product-model.js' | asset_url }}" defer></script>
    {%- endif -%}

    {%- liquid
      if product.selected_or_first_available_variant.featured_media
        assign seo_media = product.selected_or_first_available_variant.featured_media
      else
        assign seo_media = product.featured_media
      endif
    -%}

    <script type="application/ld+json">
      {{ product | structured_data }}
    </script>

    <script>
      /* Scroll to Judge.me reviews when stars are clicked — tries all known selectors */
      document.addEventListener('DOMContentLoaded', function() {
        var starsLink = document.querySelector('.originea-stars-link');
        if (!starsLink) return;

        starsLink.addEventListener('click', function(e) {
          e.preventDefault();
          /* Judge.me uses different containers depending on install method */
          var selectors = [
            '#jdgm-widget',
            '#judgeme_product_reviews',
            '.jdgm-widget',
            '.jdgm-rev-widg',
            '[data-id="jdgm-widget"]',
            '.shopify-app-block'
          ];
          var target = null;
          for (var i = 0; i < selectors.length; i++) {
            target = document.querySelector(selectors[i]);
            if (target) break;
          }
          if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });
    </script>
  </div>
</product-info>

