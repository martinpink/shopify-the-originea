{% comment %} Callout section — The Originea v2 Design {% endcomment %}
{% comment %} Terracotta (#c8855a) bg, large display-script word as bg decoration, centered editorial text {% endcomment %}

<section class="originea-callout" style="background-color: {{ section.settings.bg_color }};">
  <div class="page-width originea-callout__inner">

    {%- if section.settings.script_word != blank -%}
      {% comment %} Large decorative script word in background {% endcomment %}
      <div class="originea-callout__script display-script" aria-hidden="true">
        {{ section.settings.script_word }}
      </div>
    {%- endif -%}

    <h2 class="originea-callout__heading{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        style="color: {{ section.settings.heading_color }};">
      {{ section.settings.heading }}
    </h2>

    {%- if section.settings.body_text != blank -%}
      <p class="originea-callout__body{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
         style="color: {{ section.settings.body_color }};">
        {{ section.settings.body_text }}
      </p>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Originea Callout",
  "tag": "div",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#c8855a"
    },
    {
      "type": "text",
      "id": "script_word",
      "label": "Decorative script word (background)",
      "default": "sensoriel"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Le fruit. La lumière. La main."
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#151605"
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body text",
      "default": "Déshydraté lentement à basse température. Sans additifs. Sans sucres ajoutés. Rien que le fruit — dans toute sa vérité."
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body text color",
      "default": "#4a2e18"
    }
  ],
  "presets": [
    {
      "name": "Originea Callout"
    }
  ]
}
{% endschema %}
