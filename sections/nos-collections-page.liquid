{{ 'originea-sections.css' | asset_url | stylesheet_tag }}
{{ 'mask-blobs.css' | asset_url | stylesheet_tag }}

<div class="nos-collections-page color-{{ section.settings.color_scheme }}">
  <div class="page-width">

    <div class="nos-collections-page__header">
      <h1 class="nos-collections-page__title">{{ section.settings.heading }}</h1>
      <p class="nos-collections-page__subtitle">{{ section.settings.subtitle }}</p>
    </div>

    <div class="nos-collections-page__grid">
      {%- for collection in collections -%}
        {%- unless collection.handle == 'all' or collection.handle == 'all-collection-theoriginea' or collection.all_products_count == 0 -%}
          <a href="{{ collection.url }}" class="nos-collections-page__card">
            <div class="nos-collections-page__card-image shape--blob">
              {%- if collection.image -%}
                <img
                  src="{{ collection.image | image_url: width: 600 }}"
                  alt="{{ collection.title | escape }}"
                  width="600"
                  height="400"
                  loading="lazy"
                >
              {%- elsif collection.products.first.featured_image -%}
                <img
                  src="{{ collection.products.first.featured_image | image_url: width: 600 }}"
                  alt="{{ collection.title | escape }}"
                  width="600"
                  height="400"
                  loading="lazy"
                >
              {%- else -%}
                <div class="nos-collections-page__card-placeholder"></div>
              {%- endif -%}
              <div class="nos-collections-page__card-overlay">
                <span class="nos-collections-page__card-cta">Découvrir</span>
              </div>
            </div>
            <div class="nos-collections-page__card-info">
              <h2 class="nos-collections-page__card-title">{{ collection.title }}</h2>
              <span class="nos-collections-page__card-count">{{ collection.all_products_count }} produit{% if collection.all_products_count > 1 %}s{% endif %}</span>
            </div>
          </a>
        {%- endunless -%}
      {%- endfor -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Nos Collections Page",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Nos Collections"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Explorez l'univers The Originea — chaque collection raconte une histoire"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Nos Collections Page"
    }
  ]
}
{% endschema %}
