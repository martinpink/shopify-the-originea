{{ 'originea-sections.css' | asset_url | stylesheet_tag }}

{%- if collection.handle == 'all' or collection.handle == 'all-collection-theoriginea' -%}

{%- assign active_tag = current_tags | first | downcase -%}

<div class="boutique-header color-{{ section.settings.color_scheme }}">
  <div class="page-width boutique-header__inner">
    <h1 class="boutique-header__title">{{ section.settings.heading }}</h1>
    <p class="boutique-header__subtitle">{{ section.settings.subtitle }}</p>

    <div class="boutique-header__filters" role="navigation" aria-label="Filtrer par catégorie">
      <a href="/collections/all"
         class="boutique-filter-chip{% if active_tag == blank %} boutique-filter-chip--active{% endif %}">
        Tout
      </a>
      <a href="/collections/all/agrumes"
         class="boutique-filter-chip{% if active_tag == 'agrumes' %} boutique-filter-chip--active{% endif %}">
        Agrumes
      </a>
      <a href="/collections/all/botaniques"
         class="boutique-filter-chip{% if active_tag == 'botaniques' %} boutique-filter-chip--active{% endif %}">
        Botaniques
      </a>
      <a href="/collections/all/herbes-fleurs"
         class="boutique-filter-chip{% if active_tag == 'herbes-fleurs' %} boutique-filter-chip--active{% endif %}">
        Herbes &amp; Fleurs
      </a>
      <a href="/collections/all/mariage"
         class="boutique-filter-chip{% if active_tag == 'mariage' %} boutique-filter-chip--active{% endif %}">
        Mariage
      </a>
    </div>
  </div>
</div>

{%- endif -%}

{% schema %}
{
  "name": "Boutique Filter Header",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tous nos produits"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Agrumes et fruits artisanaux déshydratés · Provence, France"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    }
  ],
  "presets": [
    {
      "name": "Boutique Filter Header"
    }
  ]
}
{% endschema %}
